# Keep the image lean and — critically — keep local secrets OUT of it.
.git
.gitignore
.dockerignore
.claude/
.devcontainer/

# Secrets / local credentials (never bake into an image)
.mcp.json
gmail_credentials.json
token.json
*.env
.env

# Local data / caches
data/
*.db
__pycache__/
*.pyc
.pytest_cache/

# Backend image doesn't run the dashboard or tests
app.py
tests/
