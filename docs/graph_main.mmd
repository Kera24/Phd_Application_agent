---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	intake(intake)
	discover(discover)
	process_opp(process_opp)
	approval(approval)
	scheduler(scheduler)
	finalize(finalize)
	__end__([<p>__end__</p>]):::last
	__start__ --> intake;
	approval -.-> finalize;
	approval -.-> scheduler;
	discover -.-> approval;
	discover -.-> process_opp;
	intake --> discover;
	process_opp --> approval;
	scheduler --> approval;
	finalize --> __end__;
	approval -.-> approval;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
